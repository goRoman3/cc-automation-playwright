# ── Application ──────────────────────────────────────────────────────────────
BASE_URL=https://atmossystemstaging.callcabinet.com

# ── Single-user test credentials ─────────────────────────────────────────────
# Use a dedicated QA mailbox, not a personal account.
TEST_EMAIL=qa-automation@example.com
TEST_PASSWORD=
# Required for the password-reset test suite. Set to the new password to apply.
TEST_NEW_PASSWORD=

# ── Multi-user test credentials (JSON, overrides single-user vars if set) ─────
# TEST_USERS_JSON=[{"alias":"resetUser","email":"qa.reset@example.com","password":"OldPass1!","newPassword":"NewPass1!"},{"alias":"resetUser2","email":"qa.reset2@example.com","password":"OldPass2!","newPassword":"NewPass2!"}]

# ── Gmail API (OAuth 2.0 — never use account password) ───────────────────────
# See README for how to obtain these values via Google Cloud Console.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_DEFAULT_USER_ID=me
